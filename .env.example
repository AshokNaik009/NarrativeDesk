# LLM API Keys
GROQ_API_KEY=your_groq_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/narrativedesk

# Execution Venue: "alpaca" (equities) or "bybit" (crypto perps)
EXECUTION_VENUE=alpaca

# Alpaca Paper Trading (if EXECUTION_VENUE=alpaca)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_API_SECRET=your_alpaca_secret_here

# Bybit Testnet (if EXECUTION_VENUE=bybit) - crypto perpetuals with leverage, funding, liquidations
BYBIT_TESTNET_KEY=your_bybit_testnet_key_here
BYBIT_TESTNET_SECRET=your_bybit_testnet_secret_here

# CryptoPanic
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# Environment
NODE_ENV=development
PORT=3000

# Dashboard
DASHBOARD_SECRET=your_secret_here

# Etherscan (whale balance changes, on-chain signals)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
